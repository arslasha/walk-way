# Walk-Way Environment Variables Template

# Database configuration (PostGIS)
POSTGRES_DB=walkway_db
POSTGRES_USER=walkway_user
POSTGRES_PASSWORD=walkway_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django server configuration
DJANGO_SECRET_KEY=dev-secret-key-change-me-in-production
DJANGO_DEBUG=True

# External API Integrations (Optional for basic setup, required for full feature set)
# OpenAI API is used for LLM mood/vibe enrichment of places
OPENAI_API_KEY=your-openai-api-key-here

# OpenRouteService API is used for calculated walking polyline generation (Phase 2)
ORS_API_KEY=your-openrouteservice-api-key-here
